# Application
NODE_ENV=development
PORT=3000
APP_NAME=node57
APP_VERSION=1.0.0

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=node57_db
DB_USER=node57_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info